# Server
PORT=4000
NODE_ENV=production

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=badrikidukan

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend (use production URL in prod, e.g. https://yourdomain.com)
FRONTEND_ORIGIN=http://localhost:3000

# Email - ethereal is dev-only. On Render use Resend or SendGrid API (SMTP ports blocked).
# Options: ethereal (dev), resend (recommended), sendgrid, gmail, ses, smtp
EMAIL_PROVIDER=ethereal

# Production on Render (password reset, order emails, etc.):
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM=BadrikiDukan <onboarding@resend.dev>
# After verifying your domain in Resend, use e.g.:
# MAIL_FROM=BadrikiDukan <noreply@yourdomain.com>

# Email (SMTP) - for EMAIL_PROVIDER=smtp or gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Email (Resend) - for EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxx

# Email (SendGrid) - for EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxx

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Cloudinary (optional - when set, images are stored in Cloudinary instead of local disk)
# Get credentials from https://console.cloudinary.com
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
