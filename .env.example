# Server
PORT=4000
NODE_ENV=production

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=badrikidukan

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend (use production URL in prod, e.g. https://yourdomain.com)
FRONTEND_ORIGIN=http://localhost:3000

# Email - set EMAIL_PROVIDER for production (ethereal is dev-only)
# Options: ethereal (dev), gmail, sendgrid, ses, smtp
EMAIL_PROVIDER=ethereal

# Email (SMTP) - for EMAIL_PROVIDER=smtp or gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
